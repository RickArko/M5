# M5 Forecasting — environment configuration
# Copy this file to `.env` and adjust if you want to override defaults.
# `make install` (and `make bootstrap`) seed this from .env.example automatically.

# ── Virtual environment ──────────────────────────────────────────────
# uv places the project venv at ./.venv by default. We pin it explicitly
# so it's discoverable, and so `.vscode/settings.json` and the Makefile
# can both rely on the same path.
#   Activate manually:   source .venv/bin/activate
#   VSCode:              auto-activated via .vscode/settings.json
#   No activation:       `uv run <cmd>` works without activating
UV_PROJECT_ENVIRONMENT=.venv

# Where raw + processed data lives (relative to repo root or absolute path)
DATA_DIR=data

# Reproducibility: global random seed
M5_SEED=42

# Forecast horizon (M5 evaluation = 28 days)
M5_HORIZON=28

# Cross-validation: number of windows (each `H` days)
M5_N_WINDOWS=3

# How many trailing days to keep when building training data
# (full series = ~1941 days; 400 days is a fast, defensible default)
M5_LAST_N_DAYS=400

# How many series to subsample for fast iteration (-1 = all 30,490)
M5_N_SERIES=-1

# Logging level: TRACE | DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
