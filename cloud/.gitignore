# Per-user / per-machine Terraform working state
# Note: .terraform.lock.hcl is intentionally NOT ignored — pin provider versions
# for reproducible installs across machines (Terraform best practice).
terraform/*/terraform.tfvars
terraform/*/.terraform/
terraform/*/terraform.tfstate
terraform/*/terraform.tfstate.backup
terraform/*/*.tfplan

# Local testing scratch
*.local.tfvars
